<?php
/**
 * Plugin Name: Research Team Manager
 * Plugin URI: https://example.com/research-team-manager
 * Description: A comprehensive plugin to manage research team members and publications with Google Scholar integration.
 * Version: 1.0.0
 * Author: Research Team Manager
 * License: GPL v2 or later
 * Text Domain: research-team-manager
 * Domain Path: /languages
 */

if (!defined('ABSPATH')) {
    exit;
}

define('RTM_VERSION', '1.0.0');
define('RTM_PLUGIN_URL', plugin_dir_url(__FILE__));
define('RTM_PLUGIN_PATH', plugin_dir_path(__FILE__));
define('RTM_PLUGIN_BASENAME', plugin_basename(__FILE__));

class ResearchTeamManager {
    
    private static $instance = null;
    
    public static function get_instance() {
        if (null === self::$instance) {
            self::$instance = new self();
        }
        return self::$instance;
    }
    
    private function __construct() {
        add_action('init', array($this, 'init'));
        add_action('plugins_loaded', array($this, 'load_textdomain'));
        
        // Add admin notice to confirm plugin is loading
        add_action('admin_notices', array($this, 'test_admin_notice'));
        
        register_activation_hook(__FILE__, array($this, 'activate'));
        register_deactivation_hook(__FILE__, array($this, 'deactivate'));
    }
    
    public function test_admin_notice() {
        // Remove this after confirming plugin works
        if (current_user_can('manage_options')) {
            $screen = get_current_screen();
            if ($screen && $screen->id === 'plugins') {
                echo '<div class="notice notice-info"><p>Research Team Manager plugin is active and loading.</p></div>';
            }
        }
    }
    
    public function init() {
        // Load dependencies first
        $this->load_dependencies();
        
        // Initialize hooks only after dependencies are loaded
        $this->init_hooks();
        
        // Ensure post type is registered
        if (!post_type_exists('team_member') && class_exists('RTM_Post_Types')) {
            $post_types = new RTM_Post_Types();
            $post_types->register_post_types();
        }
    }
    
    public function load_textdomain() {
        load_plugin_textdomain('research-team-manager', false, dirname(RTM_PLUGIN_BASENAME) . '/languages/');
    }
    
    private function load_dependencies() {
        // Check if files exist before loading
        $files = array(
            'includes/class-rtm-post-types.php',
            'includes/class-rtm-custom-fields.php',
            'includes/class-rtm-publications.php',
            'includes/class-rtm-scholar-scraper.php',
            'admin/class-rtm-admin.php',
            'public/class-rtm-public.php'
        );
        
        foreach ($files as $file) {
            $filepath = RTM_PLUGIN_PATH . $file;
            if (file_exists($filepath)) {
                require_once $filepath;
            } else {
                error_log('RTM Plugin: Missing file - ' . $filepath);
            }
        }
    }
    
    private function init_hooks() {
        // Initialize classes with existence check
        if (class_exists('RTM_Post_Types')) {
            new RTM_Post_Types();
        }
        
        if (class_exists('RTM_Custom_Fields')) {
            new RTM_Custom_Fields();
        }
        
        if (class_exists('RTM_Publications')) {
            new RTM_Publications();
        }
        
        if (class_exists('RTM_Scholar_Scraper')) {
            new RTM_Scholar_Scraper();
        }
        
        if (is_admin() && class_exists('RTM_Admin')) {
            new RTM_Admin();
        }
        
        if (class_exists('RTM_Public')) {
            new RTM_Public();
        }
    }
    
    public function activate() {
        $this->create_tables();
        flush_rewrite_rules();
    }
    
    public function deactivate() {
        flush_rewrite_rules();
    }
    
    private function create_tables() {
        global $wpdb;
        
        $publications_table = $wpdb->prefix . 'rtm_publications';
        
        $charset_collate = $wpdb->get_charset_collate();
        
        $sql = "CREATE TABLE $publications_table (
            id mediumint(9) NOT NULL AUTO_INCREMENT,
            title text NOT NULL,
            authors text NOT NULL,
            journal varchar(255) DEFAULT '' NOT NULL,
            year int(4) NOT NULL,
            citations int(11) DEFAULT 0 NOT NULL,
            url varchar(500) DEFAULT '' NOT NULL,
            google_scholar_id varchar(100) DEFAULT '' NOT NULL,
            abstract text DEFAULT '' NOT NULL,
            date_created datetime DEFAULT CURRENT_TIMESTAMP NOT NULL,
            date_updated datetime DEFAULT CURRENT_TIMESTAMP ON UPDATE CURRENT_TIMESTAMP NOT NULL,
            PRIMARY KEY (id)
        ) $charset_collate;";
        
        require_once(ABSPATH . 'wp-admin/includes/upgrade.php');
        dbDelta($sql);
    }
}

function research_team_manager() {
    return ResearchTeamManager::get_instance();
}

research_team_manager();